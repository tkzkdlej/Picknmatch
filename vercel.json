{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "geolocation=(), microphone=(), camera=(), payment=(), usb=(), interest-cohort=()" },
        { "key": "X-Frame-Options", "value": "DENY" },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; base-uri 'self'; frame-ancestors 'none'; object-src 'none'; form-action 'self'; upgrade-insecure-requests; block-all-mixed-content; script-src 'self' https://dapi.kakao.com https://t1.daumcdn.net https://t1.kakaocdn.net; connect-src 'self' https://dapi.kakao.com https://map.kakao.com https://images.unsplash.com https://fonts.googleapis.com https://fonts.gstatic.com https://cdn.jsdelivr.net; img-src 'self' data: https://images.unsplash.com https://map.kakao.com https://t1.daumcdn.net https://t1.kakaocdn.net https://*.daumcdn.net https://*.kakaocdn.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.jsdelivr.net; font-src 'self' https://fonts.gstatic.com https://cdn.jsdelivr.net data:; frame-src https://map.kakao.com; worker-src 'self';"
        }
      ]
    }
  ],
  "redirects": [
    { "source": "/index.html", "destination": "/main/", "permanent": true },
    { "source": "/main.html", "destination": "/main/", "permanent": true },
    { "source": "/company.html", "destination": "/introduce/", "permanent": true },

    { "source": "/achievement.html", "destination": "/achievement/", "permanent": true },
    { "source": "/career.html", "destination": "/career/", "permanent": true },
    { "source": "/greeting.html", "destination": "/greeting/", "permanent": true },
    { "source": "/headhunting.html", "destination": "/headhunting/", "permanent": true },
    { "source": "/location.html", "destination": "/location/", "permanent": true },
    { "source": "/members.html", "destination": "/members/", "permanent": true },
    { "source": "/position.html", "destination": "/position/", "permanent": true },
    { "source": "/privacy.html", "destination": "/privacy/", "permanent": true },
    { "source": "/recruitment.html", "destination": "/recruitment/", "permanent": true },
    { "source": "/reference.html", "destination": "/reference/", "permanent": true },
    { "source": "/request-career.html", "destination": "/request-career/", "permanent": true },
    { "source": "/request-headhunting.html", "destination": "/request-headhunting/", "permanent": true },
    { "source": "/request-recruitment.html", "destination": "/request-recruitment/", "permanent": true },
    { "source": "/request-reference.html", "destination": "/request-reference/", "permanent": true },
    { "source": "/resume.html", "destination": "/resume/", "permanent": true },
    { "source": "/strength.html", "destination": "/strength/", "permanent": true },
    { "source": "/terms.html", "destination": "/terms/", "permanent": true }
  ]
}

